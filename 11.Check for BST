class Node {
    int data;
    Node left;
    Node right;

    Node(int val) {
        data = val;
        left = null;
        right = null;
    }
}

class Solution {

    boolean check(Node root, long min, long max) {

        if (root == null)
            return true;

        if (root.data <= min || root.data >= max)
            return false;

        return check(root.left, min, root.data)
                && check(root.right, root.data, max);
    }

    public boolean isBST(Node root) {

        return check(root, Long.MIN_VALUE, Long.MAX_VALUE);
    }
}

public class Main {

    public static void main(String[] args) {

        // Nodes banao
        Node a = new Node(10);
        Node b = new Node(5);
        Node c = new Node(20);
        Node d = new Node(2);
        Node e = new Node(8);
        Node f = new Node(15);
        Node g = new Node(25);

        // Nodes ko connect karo
        a.left = b;
        a.right = c;

        b.left = d;
        b.right = e;

        c.left = f;
        c.right = g;

        // Root
        Node root = a;

        // Solution object
        Solution obj = new Solution();

        // Function Call
        boolean ans = obj.isBST(root);

        System.out.println("Is BST : " + ans);
    }
}
