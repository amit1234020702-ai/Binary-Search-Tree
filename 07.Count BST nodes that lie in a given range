class Node {
    int data;
    Node left, right;

    Node(int d) {
        data = d;
        left = right = null;
    }
}

class Solution {

    int getCount(Node root, int l, int h) {

        if (root == null)
            return 0;

        if (root.data < l)
            return getCount(root.right, l, h);

        else if (root.data > h)
            return getCount(root.left, l, h);

        else
            return 1 + getCount(root.left, l, h) + getCount(root.right, l, h);
    }
}

public class Main {

    public static void main(String[] args) {

        // Step 1 : Nodes banao

        Node a = new Node(10);
        Node b = new Node(5);
        Node c = new Node(50);
        Node d = new Node(1);
        Node e = new Node(7);
        Node f = new Node(40);
        Node g = new Node(100);

        // Step 2 : Nodes connect karo

        a.left = b;
        a.right = c;

        b.left = d;
        b.right = e;

        c.left = f;
        c.right = g;

        // Step 3 : Root set karo

        Node root = a;

        // Step 4 : Object banao

        Solution obj = new Solution();

        // Step 5 : Range

        int l = 5;
        int h = 45;

        // Step 6 : Function Call

        int ans = obj.getCount(root, l, h);

        // Step 7 : Print

        System.out.println(ans);
    }
}
