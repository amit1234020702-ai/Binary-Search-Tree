import java.util.*;

class Node {

    int data;
    Node left, right;

    Node(int val) {
        data = val;
        left = right = null;
    }
}

class Solution {

    public void inorder(Node root, ArrayList<Integer> arr) {

        if(root==null)
            return;

        inorder(root.left,arr);

        arr.add(root.data);

        inorder(root.right,arr);
    }

    public int kthSmallest(Node root,int k){

        ArrayList<Integer> arr=new ArrayList<>();

        inorder(root,arr);

        if(arr.size()<k)
            return -1;

        return arr.get(k-1);
    }
}

public class Main {

    public static void main(String[] args){

        Node a=new Node(5);
        Node b=new Node(3);
        Node c=new Node(7);
        Node d=new Node(2);
        Node e=new Node(4);
        Node f=new Node(6);
        Node g=new Node(8);

        a.left=b;
        a.right=c;

        b.left=d;
        b.right=e;

        c.left=f;
        c.right=g;

        Node root=a;

        Solution obj=new Solution();

        int ans=obj.kthSmallest(root,4);

        System.out.println(ans);
    }
}
