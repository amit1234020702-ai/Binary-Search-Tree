class Node {
    int data;
    Node left, right;

    Node(int data) {
        this.data = data;
        left = null;
        right = null;
    }
}

class Solution {

    public int minValue(Node root) {

        if (root == null)
            return -1;

        if (root.left == null)
            return root.data;

        return minValue(root.left);
    }
}

public class Main {

    public static void main(String[] args) {

        /*
                  10
                 /  \
                5    20
               /
              2
        */

        Node root = new Node(10);

        root.left = new Node(5);
        root.right = new Node(20);

        root.left.left = new Node(2);

        Solution obj = new Solution();

        System.out.println("Minimum Element = " + obj.minValue(root));
    }
}
