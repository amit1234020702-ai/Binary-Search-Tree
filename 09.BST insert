class Node {
    int data;
    Node left, right;

    Node(int val) {
        data = val;
        left = right = null;
    }
}

class Solution {

    Node insert(Node root, int key) {

        // Tree empty hai
        if (root == null)
            return new Node(key);

        // Right subtree
        if (root.data < key) {
            root.right = insert(root.right, key);
        }

        // Left subtree
        else if (root.data > key) {
            root.left = insert(root.left, key);
        }

        return root;
    }
}

public class Main {

    static void inorder(Node root) {

        if (root == null)
            return;

        inorder(root.left);
        System.out.print(root.data + " ");
        inorder(root.right);
    }

    public static void main(String[] args) {

        Node a = new Node(10);
        Node b = new Node(5);
        Node c = new Node(15);

        a.left = b;
        a.right = c;

        Node root = a;

        Solution obj = new Solution();

        root = obj.insert(root, 12);

        inorder(root);
    }
}
